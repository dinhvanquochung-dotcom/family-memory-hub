rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Any Firebase-authenticated user may read and write.
    // The email whitelist is enforced in the client (ALLOWED_EMAILS).
    // Keeping rules simple avoids false denials from token-field mismatches.

    match /memories/{memoryId} {
      allow read, write: if request.auth != null;
    }

    match /comments/{memoryId}/items/{commentId} {
      allow read, write: if request.auth != null;
    }
  }
}
